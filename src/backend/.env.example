DATABASE_URL="postgresql://postgres:postgres@localhost:5433/pitch_folio_track?schema=public"
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
# Optional rotation: kid:secret pairs (first is current)
# JWT_ACCESS_KEYS="v1:access_secret_current,v0:access_secret_old"
# JWT_REFRESH_KEYS="v1:refresh_secret_current,v0:refresh_secret_old"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
FRONTEND_URL="http://localhost:8080"

# Midtrans (Sandbox/Production)
# Sandbox server key looks like: SB-Mid-server-...
# Production server key looks like: Mid-server-...
MIDTRANS_SERVER_KEY="SB-Mid-server-CHANGE_ME"
CORS_ALLOW_NO_ORIGIN="true"
RATE_LIMIT_TTL="60"
RATE_LIMIT_LIMIT="120"
AUTH_MAX_FAILED_ATTEMPTS="5"
AUTH_LOCKOUT_MINUTES="15"
AUDIT_LOG_RETENTION_DAYS="90"
REQUEST_BODY_LIMIT="1mb"
CSRF_ENABLED="true"
NODE_ENV="development"
