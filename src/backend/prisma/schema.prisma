// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  address   String?
  phone     String?
  companyName String?
  refreshTokenHash String?
  refreshTokenJti String?
  failedLoginAttempts Int @default(0)
  lockoutUntil DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships CompanyMember[]
}

model Company {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  taxId     String?
  currency  String   @default("IDR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     CompanyMember[]
  products    Product[]
  sales       Sale[]
  purchases   Purchase[]
  categories  PurchaseCategory[]
  receivables Receivable[]
  payables    Payable[]
  customers   Customer[]
  suppliers   Supplier[]
  taxCodes    TaxCode[]
  accounts    Account[]
  journalEntries JournalEntry[]
  fixedAssets FixedAsset[]
  subscription Subscription?
}

model CompanyMember {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  role      String   @default("owner")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model Product {
  id        String   @id @default(uuid())
  companyId String
  code      String?
  name      String
  type      String   @default("barang")
  unit      String   @default("pcs")
  buyPrice  Int      @default(0)
  price     Int
  stock     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales   Sale[]
  purchases Purchase[]

  @@index([companyId])
  @@unique([companyId, name])
  @@unique([companyId, code])
}

model Sale {
  id           String   @id @default(uuid())
  companyId    String
  productId    String
  quantity     Int
  pricePerUnit Int
  totalPrice   Int
  soldAt       DateTime
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([productId])
}

model PurchaseCategory {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Purchase {
  id         String   @id @default(uuid())
  companyId  String
  categoryId String
  productId  String?
  itemName   String
  supplier   String?
  quantity   Int
  unitCost   Int
  totalCost  Int
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category PurchaseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  product  Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([categoryId])
  @@index([productId])
}

model Receivable {
  id           String   @id @default(uuid())
  companyId    String
  customerName String
  description  String
  amount       Int
  paidAmount   Int
  dueDate      DateTime
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Payable {
  id           String   @id @default(uuid())
  companyId    String
  supplierName String
  description  String
  amount       Int
  paidAmount   Int
  dueDate      DateTime
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Subscription {
  id        String   @id @default(uuid())
  companyId String   @unique
  planId    String
  status    String
  startsAt  DateTime
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Restrict)
}

model Plan {
  id          String   @id
  name        String
  price       Int
  currency    String
  period      String
  features    String[]
  recommended Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Customer {
  id        String   @id @default(uuid())
  companyId String
  name      String
  type      String
  address   String?
  email     String?
  phone     String?
  npwp      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Supplier {
  id        String   @id @default(uuid())
  companyId String
  name      String
  type      String
  address   String?
  email     String?
  phone     String?
  npwp      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model TaxCode {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  code        String
  rate        Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Account {
  id            String   @id @default(uuid())
  companyId     String
  code          String
  name          String
  type          String
  normalBalance String
  isSystem      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@unique([companyId, code])
  @@index([companyId])
}

model JournalEntry {
  id        String   @id @default(uuid())
  companyId String
  taxCodeId String?
  date      DateTime
  memo      String?
  source    String?
  sourceId  String?
  status    JournalEntryStatus @default(posted)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taxCode TaxCode? @relation(fields: [taxCodeId], references: [id], onDelete: SetNull)
  lines   JournalLine[]

  @@index([companyId])
  @@index([companyId, source, sourceId])
  @@index([taxCodeId])
}

enum JournalEntryStatus {
  draft
  posted
}

model JournalLine {
  id        String   @id @default(uuid())
  entryId   String
  accountId String
  debit     Int      @default(0)
  credit    Int      @default(0)
  memo      String?
  createdAt DateTime @default(now())

  entry  JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([entryId])
  @@index([accountId])
}

model FixedAsset {
  id                 String   @id @default(uuid())
  companyId           String
  name               String
  assetType          String   @default("tetap")
  category           String
  acquisitionDate    DateTime
  acquisitionCost    Int
  usefulLifeMonths   Int
  residualValue      Int
  depreciationMethod String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String?
  userId    String?
  action    String
  entity    String?
  entityId  String?
  route     String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
}
